#!/bin/bash
# Pre-commit hook: scan staged changes for secrets with TruffleHog

if [ -x "$HOME/.local/bin/trufflehog" ]; then
    TRUFFLEHOG="$HOME/.local/bin/trufflehog"
elif command -v trufflehog >/dev/null 2>&1; then
    TRUFFLEHOG=$(command -v trufflehog)
else
    echo "[trufflehog] not installed, skipping scan"
    exit 0
fi

echo "[trufflehog] scanning staged changes..."

SCANDIR=$(mktemp -d)
trap 'rm -rf "$SCANDIR"' EXIT

# Materialize staged content (not the worktree) so the scan matches the commit.
git diff --cached --name-only --diff-filter=ACMR -z |
    while IFS= read -r -d '' f; do
        mkdir -p "$SCANDIR/$(dirname "$f")"
        git show ":$f" > "$SCANDIR/$f" 2>/dev/null
    done

# --fail is what makes trufflehog exit non-zero on a verified finding.
if ! "$TRUFFLEHOG" filesystem "$SCANDIR" --only-verified --fail --no-update; then
    echo ""
    echo "[trufflehog] !! Potential secrets detected in staged files !!"
    echo "Review the output above. To bypass (dangerous): yadm commit --no-verify"
    exit 1
fi

echo "[trufflehog] clean."
exit 0
